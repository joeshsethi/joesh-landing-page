{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://joeshsethi.com/AiDailyBriefing/briefing.schema.json",
  "title": "Daily AI Briefing — schema v1",
  "description": "The contract between the research agent and the front end. briefing.json must validate against this.",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "meta", "gaps", "items"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when this edition was produced."
    },
    "meta": {
      "type": "object",
      "required": [
        "brandLabel",
        "dateLabel",
        "editionLine",
        "greeting",
        "intro",
        "briefingTitle",
        "summary",
        "footerLeft",
        "footerRight"
      ],
      "additionalProperties": false,
      "properties": {
        "brandLabel": { "type": "string", "minLength": 1 },
        "dateLabel": { "type": "string", "minLength": 1 },
        "editionLine": { "type": "string", "minLength": 1 },
        "greeting": { "type": "string", "minLength": 1 },
        "intro": { "type": "string", "minLength": 1 },
        "briefingTitle": { "type": "string", "minLength": 1 },
        "summary": {
          "type": "string",
          "minLength": 200,
          "description": "3-5 plain sentences connecting the day's stories into one through-line."
        },
        "footerLeft": { "type": "string", "minLength": 1 },
        "footerRight": { "type": "string", "minLength": 1 }
      }
    },
    "gaps": {
      "type": "array",
      "description": "Japan-vs-frontier tracker.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["label", "jp", "frontier", "note"],
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "jp": { "type": "integer", "minimum": 0, "maximum": 100 },
          "frontier": { "type": "integer", "minimum": 0, "maximum": 100 },
          "note": { "type": "string", "minLength": 1 }
        }
      }
    },
    "items": {
      "type": "array",
      "description": "The story cards. Aim for ~5 global + ~3-4 Japan.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "region",
          "cat",
          "source",
          "time",
          "headline",
          "dek",
          "analysis",
          "sources",
          "tags"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9]*$",
            "description": "Stable, unique per story (e.g. g1, j1)."
          },
          "region": { "enum": ["global", "japan"] },
          "cat": { "enum": ["launches", "funding", "research", "hardware"] },
          "source": { "type": "string", "minLength": 1 },
          "time": { "type": "string", "minLength": 1 },
          "headline": { "type": "string", "minLength": 1 },
          "dek": { "type": "string", "minLength": 1 },
          "analysis": {
            "type": "object",
            "required": ["happening", "now", "future"],
            "additionalProperties": false,
            "properties": {
              "happening": { "type": "string", "minLength": 1 },
              "now": { "type": "string", "minLength": 1 },
              "future": { "type": "string", "minLength": 1 }
            }
          },
          "sources": {
            "type": "array",
            "description": "Up to 4 SPECIFIC article links (target 2-3), never a homepage or search query. May be empty if every verified link turned out to be unreachable — the story still stands on its verified research; we just won't show a broken link.",
            "minItems": 0,
            "maxItems": 4,
            "items": {
              "type": "object",
              "required": ["name", "title", "url"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "title": { "type": "string", "minLength": 1 },
                "url": { "type": "string", "format": "uri", "pattern": "^https?://" }
              }
            }
          },
          "tags": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
