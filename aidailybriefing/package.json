{
  "name": "ai-daily-briefing",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A daily AI research agent that writes briefing.json for the Daily AI Briefing front end (joeshsethi.com/AiDailyBriefing).",
  "scripts": {
    "briefing": "node --env-file-if-exists=.env agent/run.js",
    "briefing:dry": "node --env-file-if-exists=.env agent/run.js --dry-run",
    "review": "node --env-file-if-exists=.env agent/review.js",
    "validate": "node agent/validate.js site/AiDailyBriefing/briefing.json",
    "verify:sources": "node agent/verify-sources.js site/AiDailyBriefing/briefing.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.69.0",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  }
}
