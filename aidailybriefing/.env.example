# ── Copy to .env and fill in. NEVER commit .env. ──
# Local dev reads this; in CI these live in GitHub repo secrets instead.

# Required for live runs. Get one at https://console.anthropic.com/
# Without it, the agent runs in dry-run/mock mode (writes a sample briefing.json).
ANTHROPIC_API_KEY=

# ── Cost tuning (all optional; these are the defaults) ──
# Model: sonnet-4-6 is ~40% cheaper than Opus and great for news. Use Opus only
# if you want maximum analytical depth (and higher cost).
# AIDB_MODEL=claude-sonnet-4-6
# Effort: low | medium | high. Lower = fewer searches + less thinking = cheaper.
# AIDB_EFFORT=medium
# Max web searches/fetches per run (the biggest cost lever).
# AIDB_MAX_SEARCHES=8

# Where the agent writes briefing.json. In this repo the page lives at
# public/AiDailyBriefing, one level up from this agent folder.
AIDB_OUT_DIR=../public/AiDailyBriefing

# ── Storage backend ──
# "file" (default) keeps feedback + archives in local/committed files — zero infra,
# perfect for running the full thing locally. "aws" uses DynamoDB + S3 (deploy).
AIDB_STORE=file

# ── AWS backend (only when AIDB_STORE=aws) ──
# In production these live in GitHub Actions secrets (agent) and Vercel env (feedback
# function), not here. For local testing against AWS, set them in .env.
# AWS_REGION=us-east-1
# AIDB_DDB_TABLE=aidb-feedback
# AIDB_S3_BUCKET=aidb-archives-<your-unique-suffix>
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
